{
  "version": "1.0.0",
  "platformVersion": "15.5.0",
  "title": "Volvix POS",
  "description": "Connect Volvix POS to 6000+ apps. Sync sales, customers, products and stock levels in real time.",
  "homepage": "https://volvix.com",
  "intent": "global",
  "audience": "public",

  "auth": { "$ref": "auth.json" },

  "triggers": {
    "sale_created": {
      "key": "sale_created",
      "noun": "Sale",
      "display": {
        "label": "New Sale",
        "description": "Triggers when a new sale (ticket) is registered in Volvix POS.",
        "important": true
      },
      "operation": {
        "type": "polling",
        "perform": {
          "url": "{{bundle.authData.api_url}}/api/sales",
          "method": "GET",
          "headers": { "X-API-Key": "{{bundle.authData.api_key}}" },
          "params": {
            "order": "created_at.desc",
            "limit": 50,
            "since": "{{bundle.meta.timestamp}}"
          }
        },
        "sample": {
          "id": "11111111-1111-1111-1111-111111111111",
          "tenant_id": "22222222-2222-2222-2222-222222222222",
          "total": 199.50,
          "currency": "MXN",
          "customer_id": null,
          "items": [{ "product_id": "p1", "qty": 2, "price": 99.75 }],
          "created_at": "2026-04-26T10:15:00Z"
        },
        "outputFields": [
          { "key": "id", "label": "Sale ID", "type": "string" },
          { "key": "total", "label": "Total", "type": "number" },
          { "key": "currency", "label": "Currency", "type": "string" },
          { "key": "customer_id", "label": "Customer ID", "type": "string" },
          { "key": "created_at", "label": "Created at", "type": "datetime" }
        ]
      }
    },

    "customer_created": {
      "key": "customer_created",
      "noun": "Customer",
      "display": {
        "label": "New Customer",
        "description": "Triggers when a new customer is added."
      },
      "operation": {
        "type": "polling",
        "perform": {
          "url": "{{bundle.authData.api_url}}/api/customers",
          "method": "GET",
          "headers": { "X-API-Key": "{{bundle.authData.api_key}}" },
          "params": { "order": "created_at.desc", "limit": 50 }
        },
        "sample": {
          "id": "c1", "name": "Juan Pérez", "email": "juan@example.com",
          "phone": "+5215555555555", "created_at": "2026-04-26T10:00:00Z"
        }
      }
    },

    "low_stock": {
      "key": "low_stock",
      "noun": "Product",
      "display": {
        "label": "Low Stock Alert",
        "description": "Triggers when a product reaches its low-stock threshold."
      },
      "operation": {
        "type": "polling",
        "perform": {
          "url": "{{bundle.authData.api_url}}/api/products",
          "method": "GET",
          "headers": { "X-API-Key": "{{bundle.authData.api_key}}" },
          "params": { "low_stock": "true" }
        },
        "sample": {
          "id": "p1", "name": "Coca-Cola 600ml", "stock": 3, "low_stock_threshold": 10
        }
      }
    }
  },

  "creates": {
    "create_product": {
      "key": "create_product",
      "noun": "Product",
      "display": {
        "label": "Create Product",
        "description": "Creates a new product in Volvix POS."
      },
      "operation": {
        "inputFields": [
          { "key": "name", "label": "Name", "type": "string", "required": true },
          { "key": "price", "label": "Price", "type": "number", "required": true },
          { "key": "sku", "label": "SKU", "type": "string" },
          { "key": "stock", "label": "Initial stock", "type": "integer", "default": "0" },
          { "key": "category", "label": "Category", "type": "string" }
        ],
        "perform": {
          "url": "{{bundle.authData.api_url}}/api/products",
          "method": "POST",
          "headers": {
            "X-API-Key": "{{bundle.authData.api_key}}",
            "Content-Type": "application/json"
          },
          "body": {
            "name": "{{bundle.inputData.name}}",
            "price": "{{bundle.inputData.price}}",
            "sku": "{{bundle.inputData.sku}}",
            "stock": "{{bundle.inputData.stock}}",
            "category": "{{bundle.inputData.category}}"
          }
        }
      }
    },

    "create_customer": {
      "key": "create_customer",
      "noun": "Customer",
      "display": {
        "label": "Create Customer",
        "description": "Creates a new customer in Volvix POS."
      },
      "operation": {
        "inputFields": [
          { "key": "name", "label": "Full name", "type": "string", "required": true },
          { "key": "email", "label": "Email", "type": "string" },
          { "key": "phone", "label": "Phone", "type": "string" },
          { "key": "rfc", "label": "RFC (MX tax ID)", "type": "string" }
        ],
        "perform": {
          "url": "{{bundle.authData.api_url}}/api/customers",
          "method": "POST",
          "headers": {
            "X-API-Key": "{{bundle.authData.api_key}}",
            "Content-Type": "application/json"
          },
          "body": {
            "name": "{{bundle.inputData.name}}",
            "email": "{{bundle.inputData.email}}",
            "phone": "{{bundle.inputData.phone}}",
            "rfc": "{{bundle.inputData.rfc}}"
          }
        }
      }
    },

    "create_sale": {
      "key": "create_sale",
      "noun": "Sale",
      "display": {
        "label": "Create Sale",
        "description": "Registers a new sale in Volvix POS."
      },
      "operation": {
        "inputFields": [
          { "key": "customer_id", "label": "Customer ID", "type": "string" },
          { "key": "total", "label": "Total amount", "type": "number", "required": true },
          { "key": "currency", "label": "Currency", "type": "string", "default": "MXN" },
          { "key": "items", "label": "Items (JSON array)", "type": "text", "required": true,
            "helpText": "[{\"product_id\":\"...\",\"qty\":1,\"price\":99.99}]" },
          { "key": "payment_method", "label": "Payment method", "type": "string",
            "choices": ["cash","card","transfer","other"] }
        ],
        "perform": {
          "url": "{{bundle.authData.api_url}}/api/sales",
          "method": "POST",
          "headers": {
            "X-API-Key": "{{bundle.authData.api_key}}",
            "Content-Type": "application/json"
          },
          "body": {
            "customer_id": "{{bundle.inputData.customer_id}}",
            "total": "{{bundle.inputData.total}}",
            "currency": "{{bundle.inputData.currency}}",
            "items": "{{bundle.inputData.items}}",
            "payment_method": "{{bundle.inputData.payment_method}}"
          }
        }
      }
    }
  },

  "searches": {}
}
