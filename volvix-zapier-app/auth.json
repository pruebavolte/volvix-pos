{
  "type": "custom",
  "description": "Volvix POS supports two authentication modes: API Key (recommended) and OAuth2.",

  "fields": [
    {
      "key": "api_url",
      "label": "API base URL",
      "type": "string",
      "required": true,
      "default": "https://app.volvix.com",
      "helpText": "Your Volvix instance URL (no trailing slash)."
    },
    {
      "key": "api_key",
      "label": "API Key",
      "type": "string",
      "required": true,
      "helpText": "Generate an API key in Volvix → Admin → Integrations → API Keys. Format: vlx_XXXXXXXX..."
    }
  ],

  "test": {
    "url": "{{bundle.authData.api_url}}/api/integrations/api-keys/whoami",
    "method": "GET",
    "headers": { "X-API-Key": "{{bundle.authData.api_key}}" }
  },

  "connectionLabel": "{{bundle.authData.api_url}} ({{bundle.authData.tenant_name}})",

  "oauth2": {
    "enabled": false,
    "_documentation_only": true,
    "authorizeUrl": {
      "url": "{{bundle.authData.api_url}}/oauth/authorize",
      "params": {
        "client_id": "{{process.env.CLIENT_ID}}",
        "redirect_uri": "{{bundle.inputData.redirect_uri}}",
        "response_type": "code",
        "scope": "read write"
      }
    },
    "getAccessToken": {
      "url": "{{bundle.authData.api_url}}/oauth/token",
      "method": "POST",
      "body": {
        "grant_type": "authorization_code",
        "code": "{{bundle.inputData.code}}",
        "client_id": "{{process.env.CLIENT_ID}}",
        "client_secret": "{{process.env.CLIENT_SECRET}}",
        "redirect_uri": "{{bundle.inputData.redirect_uri}}"
      }
    },
    "refreshAccessToken": {
      "url": "{{bundle.authData.api_url}}/oauth/token",
      "method": "POST",
      "body": {
        "grant_type": "refresh_token",
        "refresh_token": "{{bundle.authData.refresh_token}}",
        "client_id": "{{process.env.CLIENT_ID}}",
        "client_secret": "{{process.env.CLIENT_SECRET}}"
      }
    },
    "scope": "read write",
    "autoRefresh": true
  }
}
