# Variables para el pipeline de generacion de tutoriales (tutorials/).
# Copia este archivo como .env.tutorials y rellena con valores REALES.

# URL del entorno de grabacion. Recomendado: localhost (mas estable).
STAGING_URL=http://127.0.0.1:3000

# Usuario y contraseña con permisos de owner/admin para acceder a inventario.
# IMPORTANTE: NO usar credenciales de produccion publica.
STAGING_USER=tu@correo.com
STAGING_PASS=tu_password

# Opcional: TUT_HEADED=1 abre Chromium visible (debug). Default: headless.
# TUT_HEADED=1
