# =============================================================
# Volvix POS - Variables de entorno
# Copiar a .env y rellenar. Nunca commitear .env real.
# Casi todo es OPCIONAL: server.js arranca sin ninguna.
# =============================================================

# ---------- Core (opcionales, tienen default) ----------
NODE_ENV=development              # production | development
HOST=localhost                    # default localhost
PORT=3000                         # auto-detecta libre si esta ocupado
PUBLIC_DIR=.                      # carpeta de archivos estaticos
DB_PATH=./db/volvix.db            # SQLite local (offline-first)
OPEN_BROWSER=true                 # false para no abrir navegador
BASE_URL=http://localhost:3000
VOLVIX_BASE_URL=http://localhost:3000

# ---------- Auth & Seguridad ----------
JWT_SECRET=                       # OBLIGATORIO en prod
ADMIN_API_KEY=                    # endpoints /api/admin/*
ADMIN_TOKEN=
ALLOWED_ORIGINS=                  # CSV de origenes CORS en prod
PASSWORD_RESET_BASE_URL=          # URL del frontend para reset
SEED_USERS_JSON=                  # DEV only: JSON array de users semilla
DEV_PASSWORDS_JSON=               # DEV only: { "email":"pwd" }
TEST_USER_PASSWORD=
QA_EMAIL=
QA_PASSWORD=
QA_PIN=
VOLVIX_USER=
VOLVIX_PASS=

# ---------- IA ----------
ANTHROPIC_API_KEY=                # Claude para IA autonoma
OPENAI_API_KEY=                   # opcional, fallback IA

# ---------- Supabase (prod multi-tenant) ----------
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PAT=

# ---------- CFDI / SAT (Mexico) ----------
CFDI_EMISOR_RFC=
PAC_URL=
PAC_API_KEY=
PAC_USER=
PAC_PASS=
SAT_API_KEY=
SAT_PAC_URL=
FINKOK_HOST=
FINKOK_USER=
FINKOK_PASS=

# ---------- Pagos ----------
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
SQUARE_ACCESS_TOKEN=
APPLE_MERCHANT_ID=
APPLE_PAY_MERCHANT_CERT_PATH=
APPLE_PAY_MERCHANT_KEY_PATH=
GOOGLE_MERCHANT_ID=
GOOGLE_API_KEY=
BBVA_API_KEY=
CODI_BANK_API_KEY=
CODI_MERCHANT_ID=
SPEI_CLABE=
SPEI_BENEFICIARY=
PIX_KEY=
PIX_MERCHANT_NAME=
PIX_MERCHANT_CITY=
QR_WEBHOOK_SECRET=

# ---------- Mensajeria ----------
SENDGRID_API_KEY=
SENDGRID_FROM=
SENDGRID_FROM_NAME=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_FROM=
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_GRAPH_VERSION=v19.0
TELEGRAM_BOT_TOKEN=

# ---------- Marketplaces ----------
SHOPIFY_SHOP_DOMAIN=
SHOPIFY_ACCESS_TOKEN=
SHOPIFY_API_VERSION=2024-10
SHOPIFY_WEBHOOK_SECRET=
MERCADOLIBRE_APP_ID=
MERCADOLIBRE_APP_SECRET=
MERCADOLIBRE_REDIRECT_URI=
MERCADOLIBRE_SITE=MLM
AMAZON_LWA_TOKEN=
AMAZON_MARKETPLACE_ID=
AMAZON_SP_HOST=

# ---------- Push / PWA ----------
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:soporte@volvix.app

# ---------- Mobile (R24) ----------
MOBILE_APP_VERSION=
MOBILE_MIN_SUPPORTED=
MOBILE_FORCE_UPDATE=false

# ---------- AWS / Cloud ----------
AWS_ACCESS_KEY=
AWS_SECRET=

# ---------- Observabilidad / Anti-fraude ----------
FRAUD_THRESHOLD=0.7
BLOCKCHAIN_ANCHOR_MIN_USD=1000
WEBHOOK_URL=
HEADLESS=true
CI=false

# ---------- Integraciones GitHub ----------
GH_OWNER=
GH_REPO=
GH_TOKEN=
GITHUB_TOKEN=

# ---------- Vercel / Railway (auto en deploy) ----------
# VERCEL=1                        # set por Vercel
# RAILWAY_ENVIRONMENT=            # set por Railway
