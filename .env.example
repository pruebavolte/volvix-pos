# ============================================================
# VOLVIX · Variables de entorno
# ============================================================
# Copia este archivo a .env y llénalo (NO subas .env a git)

# API key de Anthropic para que la IA sea REAL (no simulada)
# Obténla en: https://console.anthropic.com
# Los primeros $5 USD son gratis, un feature nuevo cuesta ~$0.03
ANTHROPIC_API_KEY=

# Puerto del servidor (opcional)
# Si no se especifica, el servidor busca puerto libre automáticamente
# PORT=3000

# Host del servidor (opcional, default: localhost)
# HOST=0.0.0.0

# Ruta de la base de datos (opcional)
# DB_PATH=./db/volvix.db

# Carpeta donde están los HTMLs (opcional, default: ./public)
# PUBLIC_DIR=./public

# Abrir navegador al arrancar (default: true)
# OPEN_BROWSER=false
