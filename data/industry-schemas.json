{
  "_meta": {
    "version": "1.0.0",
    "description": "Schemas de campos por giro de negocio. Cada giro define qué campos del producto son: requeridos, opcionales, o no aplican. Las terminologías cambian (ej. en panadería 'Nombre' es 'Nombre del pan', en restaurant 'Nombre platillo'). El admin puede activar/desactivar/locker cada campo individual via tenant_field_flags (control granular).",
    "field_categories": {
      "core": "Campos universales que siempre aplican",
      "industry": "Campos específicos del giro",
      "advanced": "Campos avanzados (IA, omnicanal, multimedia)",
      "premium": "Campos que requieren plan superior"
    },
    "field_types": {
      "text": "input texto libre",
      "number": "input numérico",
      "money": "input precio (formateado)",
      "select": "dropdown con opciones",
      "boolean": "toggle sí/no",
      "date": "fecha",
      "datetime": "fecha + hora",
      "image": "subir imagen",
      "image-multi": "subir múltiples imágenes",
      "barcode": "código de barras",
      "textarea": "texto largo",
      "tags": "lista de etiquetas",
      "file": "archivo (PDF, etc.)"
    }
  },

  "_universal": {
    "label": "Campos universales (todos los giros)",
    "fields": [
      { "key": "name", "label": "Nombre", "type": "text", "required": true, "placeholder": "Ej. Coca Cola 600ml" },
      { "key": "barcode", "label": "Código de barras", "type": "barcode", "required": false, "auto_generate": true, "placeholder": "Se auto-genera (1, 2, 3…)" },
      { "key": "price", "label": "Precio venta", "type": "money", "required": true },
      { "key": "cost", "label": "Costo", "type": "money", "required": false, "help": "Si no lo conoces, déjalo en 0" },
      { "key": "stock", "label": "Stock", "type": "number", "required": false, "default": 0 },
      { "key": "stock_min", "label": "Stock mínimo", "type": "number", "required": false, "help": "Avisar cuando baje de este número" },
      { "key": "category", "label": "Categoría", "type": "text", "required": false, "placeholder": "Bebidas, Abarrotes…" },
      { "key": "unit", "label": "Unidad", "type": "select", "options": ["pieza", "kilo", "gramo", "litro", "ml", "metro", "paquete"], "default": "pieza" },
      { "key": "iva", "label": "IVA", "type": "select", "options": ["16%", "8% frontera", "0% exento"], "default": "16%" },
      { "key": "image", "label": "Imagen", "type": "image", "required": false },
      { "key": "description", "label": "Descripción", "type": "textarea", "required": false }
    ]
  },

  "_advanced": {
    "label": "Campos avanzados (premium / superior)",
    "premium": true,
    "fields": [
      { "key": "ai_related", "label": "Productos relacionados (IA)", "type": "tags", "category": "advanced" },
      { "key": "ai_suggested_sale", "label": "Venta sugerida", "type": "tags", "category": "advanced" },
      { "key": "ai_seasonality", "label": "Estacionalidad", "type": "select", "options": ["año", "navidad", "verano", "invierno", "back-to-school"], "category": "advanced" },
      { "key": "shopify_id", "label": "Shopify ID", "type": "text", "category": "omnicanal" },
      { "key": "ml_id", "label": "MercadoLibre ID", "type": "text", "category": "omnicanal" },
      { "key": "tiktok_shop_id", "label": "TikTok Shop ID", "type": "text", "category": "omnicanal" },
      { "key": "video_url", "label": "Video del producto", "type": "text", "category": "multimedia" },
      { "key": "manual_pdf", "label": "Manual PDF", "type": "file", "category": "multimedia" },
      { "key": "images_extra", "label": "Imágenes adicionales", "type": "image-multi", "category": "multimedia" },
      { "key": "lots_multi", "label": "Lotes múltiples", "type": "boolean", "category": "inventory" },
      { "key": "warehouses_multi", "label": "Multi-almacén", "type": "boolean", "category": "inventory" },
      { "key": "costing_method", "label": "Método de costeo", "type": "select", "options": ["promedio", "FIFO", "LIFO"], "category": "finanzas" }
    ]
  },

  "_feature_flags": {
    "label": "Feature flags universales (activan secciones del modal dinámicamente)",
    "description": "Cada producto/tenant puede activar estos flags. Cuando un flag está ON, el modal renderiza la sección correspondiente. NO hay 100 modales distintos; hay UN modal universal con secciones que se activan/desactivan.",
    "flags": [
      { "key": "usa_receta",       "label": "Producto compuesto / Receta",  "section": "recipe",     "help": "Producto que se arma desde otros (six = 6 latas; hamburguesa = pan+carne+queso)" },
      { "key": "usa_compuestos",   "label": "Es paquete / kit",              "section": "kit",        "help": "Combo o kit pre-armado" },
      { "key": "usa_insumos",      "label": "Descuenta insumos al vender",   "section": "consumables","help": "Al vender, descuenta de inventario los ingredientes" },
      { "key": "usa_variantes",    "label": "Tiene variantes",               "section": "variants",   "help": "Mismo producto con tallas/colores/sabores distintos" },
      { "key": "usa_modificadores","label": "Tiene modificadores",           "section": "modifiers",  "help": "Extra queso, sin tomate, agrandar (suman/restan precio)" },
      { "key": "usa_lote",         "label": "Maneja lote",                   "section": "lot" },
      { "key": "usa_caducidad",    "label": "Maneja caducidad",              "section": "expiry" },
      { "key": "usa_serie",        "label": "Número de serie",               "section": "serial",     "help": "Electrónica, herramientas" },
      { "key": "usa_imei",         "label": "IMEI",                          "section": "imei",       "help": "Celulares" },
      { "key": "usa_vin",          "label": "VIN / NIV",                     "section": "vin",        "help": "Autos, refacciones específicas" },
      { "key": "usa_motor",        "label": "Número de motor",               "section": "motor" },
      { "key": "usa_horarios",     "label": "Restricción horaria",           "section": "schedule",   "help": "Sólo se vende en X horario (ley seca, happy hour)" },
      { "key": "usa_dias",         "label": "Días disponibles",              "section": "weekdays",   "help": "Sólo lun-vie, sólo fines de semana" },
      { "key": "usa_ley_seca",     "label": "Sujeto a ley seca",             "section": "leyseca" },
      { "key": "usa_pricing_rules","label": "Reglas de precio dinámico",     "section": "pricing",    "help": "Precio premium fuera de horario; descuento por volumen" },
      { "key": "usa_comision",     "label": "Comisión vendedor",             "section": "commission" },
      { "key": "usa_garantia",     "label": "Garantía",                      "section": "warranty" },
      { "key": "usa_peso",         "label": "Se vende por peso",             "section": "weight" },
      { "key": "usa_color",        "label": "Color",                         "section": "color" },
      { "key": "usa_talla",        "label": "Talla",                         "section": "size" },
      { "key": "usa_preparacion",  "label": "Tiempo de preparación",         "section": "prep_time",  "help": "Cocina, panadería" },
      { "key": "usa_alergenos",    "label": "Alérgenos",                     "section": "allergens",  "help": "Restaurante, panadería" },
      { "key": "usa_patente",      "label": "Patente / clave",               "section": "patent" },
      { "key": "usa_ingrediente_activo","label": "Ingrediente activo",       "section": "active_ingredient", "help": "Farmacia, naturista" },
      { "key": "usa_receta_medica","label": "Requiere receta médica",        "section": "rx" },
      { "key": "usa_temporada",    "label": "Temporal / estacional",         "section": "seasonal" },
      { "key": "usa_servicio",     "label": "Es servicio (no físico)",       "section": "service",    "help": "Citas, suscripciones, mano de obra" }
    ]
  },

  "_terminology": {
    "label": "Terminología dinámica per-tenant (cliente↔paciente↔huésped)",
    "description": "Diccionario que reemplaza términos del UI según el giro. El wiring lee data-term='X' y reemplaza el textContent.",
    "examples": {
      "doctor":         { "cliente": "Paciente", "venta": "Consulta", "ticket": "Receta" },
      "dentista":       { "cliente": "Paciente", "venta": "Tratamiento" },
      "veterinaria":    { "cliente": "Tutor", "producto": "Servicio/Medicamento" },
      "hotel":          { "cliente": "Huésped", "venta": "Reservación", "producto": "Habitación/Servicio" },
      "gimnasio":       { "cliente": "Miembro", "venta": "Inscripción", "producto": "Plan" },
      "estetica":       { "cliente": "Cliente", "venta": "Cita", "producto": "Servicio" },
      "barberia":       { "cliente": "Cliente", "venta": "Cita", "producto": "Servicio/Producto" },
      "academia":       { "cliente": "Alumno", "venta": "Inscripción", "producto": "Curso" },
      "iglesia":        { "cliente": "Miembro", "venta": "Donación" },
      "restaurante":    { "cliente": "Comensal", "venta": "Orden", "ticket": "Cuenta" },
      "taller":         { "cliente": "Cliente", "venta": "Servicio", "producto": "Refacción/Mano de obra" }
    }
  },

